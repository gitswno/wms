#!/data/data/com.termux/files/usr/bin/env python3
# 在/storage/emulated/0/Download/wms中搜索关键词并显示货位，也就是从关键词开始，往前搜索到的第一个冒号所在行。
# 用法 python ss keyword
# 支持分支条件，例: python ss "keyword1|keyword2"

import sys
import re

def main():
    if len(sys.argv) < 2:
        print("用法: {} <keyword>".format(sys.argv[0]))
        print("示例: {} 好|坏".format(sys.argv[0]))
        print("示例: {} 猫".format(sys.argv[0]))
        sys.exit(1)
    
    # 直接使用sys.argv[1]获取参数，确保完整传递
    keyword = sys.argv[1]
    
    # 添加调试信息 - 打印接收到的参数
    print(f"接收到的参数: {keyword}")
    
    file_path = "/storage/emulated/0/Download/wms/wms.txt"
    
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            lines = f.readlines()
    except FileNotFoundError:
        print("错误: 找不到文件 {}".format(file_path))
        sys.exit(1)
    
    # 定义颜色
    RED = '\033[31m'
    GREEN = '\033[32m'
    WHITE = '\033[37m'
    NC = '\033[0m'  # No Color
    
    # 检查是否是分支选项（包含|符号）
    if '|' in keyword:
        # 创建正则表达式模式，匹配任意一个关键词
        escaped_keywords = [re.escape(k) for k in keyword.split('|')]
        
        # 尝试不同的匹配方式
        print("\n尝试不同的匹配方式:")
        
        # 1. 不使用单词边界，直接匹配子字符串
        pattern_substring = re.compile('|'.join(escaped_keywords), re.IGNORECASE)
        print(f"直接匹配子字符串的正则: {pattern_substring.pattern}")
        
        # 2. 使用单词边界（原来的方式）
        pattern_boundary = re.compile(r'\b(?:' + '|'.join(escaped_keywords) + r')\b', re.IGNORECASE)
        print(f"使用单词边界的正则: {pattern_boundary.pattern}")
        
        # 3. 不区分大小写
        pattern_case_insensitive = re.compile('|'.join(escaped_keywords), re.IGNORECASE)
        print(f"不区分大小写的正则: {pattern_case_insensitive.pattern}")
        
        # 使用直接匹配子字符串的方式
        pattern = pattern_substring
        pattern_name = "直接匹配子字符串"
    else:
        # 简单字符串匹配
        pattern = re.compile(re.escape(keyword), re.IGNORECASE)
        print(f"构建的正则表达式: {pattern.pattern}")
        
        # 尝试不同的匹配方式
        print("\n尝试不同的匹配方式:")
        
        # 1. 不使用单词边界
        pattern_no_boundary = re.compile(re.escape(keyword), re.IGNORECASE)
        print(f"不使用单词边界的正则: {pattern_no_boundary.pattern}")
        
        # 2. 不区分大小写
        pattern_case_insensitive = re.compile(re.escape(keyword), re.IGNORECASE)
        print(f"不区分大小写的正则: {pattern_case_insensitive.pattern}")
        
        pattern = pattern
        pattern_name = "简单字符串匹配"
    
    # 查找所有包含关键词的行
    found = False
    print(f"\n使用 {pattern_name} 搜索:")
    for line_num, line in enumerate(lines, 1):
        if pattern.search(line):
            found = True
            # 高亮关键词
            def replace_match(match):
                return f"{RED}{match.group(0)}{NC}"
            
            highlighted_line = pattern.sub(replace_match, line)
            
            # 打印带颜色的行 - 只让行号显示为绿色
            print(f"【关键字行】 第 {GREEN}{line_num}{NC} 行: {highlighted_line}", end='')
            
            # 检查当前行自身是否包含英文冒号
            if ':' in line:
                print("  └─ 该行自身包含冒号，无需往上查找。")
            else:
                # 往前逐行搜索第一个冒号
                货位行 = None
                货位行号 = None
                for i in range(line_num - 1, 0, -1):
                    if ':' in lines[i-1]:
                        货位行 = lines[i-1].strip()
                        货位行号 = i
                        break
                
                if 货位行:
                    # 获取关键词的长度
                    关键词长度 = len(keyword)
                    
                    # 计算需要填充的空格数
                    货位行内容 = 货位行.split(':', 1)[0].strip()  # 只取冒号前的部分
                    货位内容长度 = len(货位行内容)
                    填充空格数 = max(0, 关键词长度 - 货位内容长度)
                    
                    # 打印货位行，并填充空格使内容对齐
                    print(f"【货位】 第 {货位行号} 行: ", end='')
                    print(f"{WHITE}{货位行}{NC}", end='')
                    print(" " * 填充空格数, end='')
                    print()  # 换行，不再添加关键词
                else:
                    # 如果一直往前找都没找到冒号行，给个提示
                    print("  └─ 往前搜索到第1行，未发现包含冒号的行。")
            
            #print("----------------------------------------")  # 分隔线
            print()  # 添加空行
    
    if not found:
        print(f"使用 {pattern_name} 未找到包含关键词的行")
        
        # 尝试其他匹配方式
        if '|' in keyword:
            # 尝试使用单词边界的匹配
            print("\n尝试使用单词边界的匹配:")
            found_boundary = False
            for line_num, line in enumerate(lines, 1):
                if re.compile(r'\b(?:' + '|'.join([re.escape(k) for k in keyword.split('|')]) + r')\b', re.IGNORECASE).search(line):
                    found_boundary = True
                    print(f"找到匹配（使用单词边界）- 第 {line_num} 行: {line}", end='')
                    break
            
            if not found_boundary:
                print("使用单词边界也未找到匹配")
                
                # 尝试不区分大小写的匹配
                print("\n尝试不区分大小写的匹配:")
                found_case_insensitive = False
                for line_num, line in enumerate(lines, 1):
                    if re.compile('|'.join([re.escape(k) for k in keyword.split('|')]), re.IGNORECASE).search(line):
                        found_case_insensitive = True
                        print(f"找到匹配（不区分大小写）- 第 {line_num} 行: {line}", end='')
                        break
                
                if not found_case_insensitive:
                    print("不区分大小写也未找到匹配")
                    print("\n可能的原因:")
                    print("1. 文件编码问题 - 尝试使用不同的编码打开文件")
                    print("2. 关键词可能包含特殊字符")
                    print("3. 文件内容可能有格式问题")
        else:
            # 尝试不使用单词边界的匹配
            print("\n尝试不使用单词边界的匹配:")
            found_no_boundary = False
            for line_num, line in enumerate(lines, 1):
                if re.compile(re.escape(keyword), re.IGNORECASE).search(line):
                    found_no_boundary = True
                    print(f"找到匹配（不使用单词边界）- 第 {line_num} 行: {line}", end='')
                    break
            
            if not found_no_boundary:
                print("不使用单词边界也未找到匹配")
                
                # 尝试不区分大小写的匹配
                print("\n尝试不区分大小写的匹配:")
                found_case_insensitive = False
                for line_num, line in enumerate(lines, 1):
                    if re.compile(re.escape(keyword), re.IGNORECASE).search(line):
                        found_case_insensitive = True
                        print(f"找到匹配（不区分大小写）- 第 {line_num} 行: {line}", end='')
                        break
                
                if not found_case_insensitive:
                    print("不区分大小写也未找到匹配")
                    print("\n可能的原因:")
                    print("1. 文件编码问题 - 尝试使用不同的编码打开文件")
                    print("2. 关键词可能包含特殊字符")
                    print("3. 文件内容可能有格式问题")

if __name__ == "__main__":
    main()
